<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>VocabPop B2L2: My Mouth's in Airplane Mode!</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/react@18/umd/react.production.min.js" crossorigin></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js" crossorigin></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Lexend:wght@400;700;900&display=swap');
        
        body { 
            font-family: 'Lexend', sans-serif; 
            background: linear-gradient(180deg, #FFF9E6 0%, #FFD1D1 100%);
            margin: 0;
            padding: 0;
            overflow-x: hidden;
            display: flex;
            justify-content: center;
            min-height: 100vh;
        }

        #root {
            width: 100%;
            max-width: 420px;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            background: transparent;
            position: relative;
        }

        .brutal-card-heavy {
            background: white;
            border: 4px solid #000;
            box-shadow: 8px 8px 0px 0px #000;
        }

        .brutal-btn {
            border: 3px solid #000;
            box-shadow: 4px 4px 0px 0px #000;
            transition: all 0.1s ease;
            touch-action: manipulation;
        }

        .brutal-btn:active:not(:disabled) {
            transform: translate(2px, 2px);
            box-shadow: 2px 2px 0px 0px #000;
        }

        .brutal-input {
            border: 3px solid #000;
            border-radius: 12px;
            padding: 10px 14px;
            outline: none;
            font-weight: 700;
            width: 100%;
            background: white;
        }

        .underline-input {
            border: none;
            border-bottom: 4px solid #5D5FEF;
            background: #F8FAFC;
            padding: 10px;
            width: 100%;
            font-size: 20px;
            font-weight: 900;
            text-align: center;
            outline: none;
        }

        .syllable-bubble {
            border: 2px solid #000;
            padding: 2px 8px;
            border-radius: 8px;
            font-weight: 700;
            font-size: 11px;
        }

        .match-item {
            border: 2px solid #F9A8D4;
            background: white;
            padding: 8px;
            border-radius: 10px;
            font-weight: 800;
            font-size: 11px;
            text-align: center;
        }

        .match-item.selected { background: #F9A8D4; color: white; transform: scale(0.95); }
        .match-item.correct { background: #86EFAC; border-color: #22C55E; color: #14532D; }

        .mic-recording {
            animation: pulse-red 1.2s infinite;
        }

        @keyframes pulse-red {
            0% { transform: scale(1); box-shadow: 0 0 0 0px rgba(239, 68, 68, 0.7); }
            70% { transform: scale(1.05); box-shadow: 0 0 0 12px rgba(239, 68, 68, 0); }
            100% { transform: scale(1); box-shadow: 0 0 0 0px rgba(239, 68, 68, 0); }
        }

        .animate-pop { animation: popIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
        @keyframes popIn { 0% { transform: scale(0.95); opacity: 0; } 100% { transform: scale(1); opacity: 1; } }
    </style>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect, useMemo, useRef } = React;

        // ⚠️ 請在此處填入您的 Google Apps Script 部署網址
        const GOOGLE_SCRIPT_URL = "https://script.google.com/macros/s/AKfycbzQVDLuSQnV3bYPyfStwsPUY8UQrePglY3476At9p4SCcXUcIJOZutv7-6OVPXyFVu7/exec"; 

        const Icons = {
            Zap: (p) => <svg width={p.size||24} height={p.size||24} viewBox="0 0 24 24" fill="currentColor" className={p.className}><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>,
            Volume2: (p) => <svg width={p.size||24} height={p.size||24} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round" className={p.className}><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg>,
            Book: (p) => <svg width={p.size||24} height={p.size||24} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round" className={p.className}><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>,
            Coach: (p) => <svg width={p.size||24} height={p.size||24} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round" className={p.className}><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>,
            Mic: (p) => <svg width={p.size||24} height={p.size||24} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round" className={p.className}><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>,
            Keyboard: (p) => <svg width={p.size||24} height={p.size||24} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round" className={p.className}><rect x="2" y="4" width="20" height="16" rx="2" ry="2"/><path d="M6 8h.01"/><path d="M10 8h.01"/><path d="M14 8h.01"/><path d="M18 8h.01"/><path d="M8 12h.01"/><path d="M12 12h.01"/><path d="M16 12h.01"/><path d="M7 16h10"/></svg>,
            Pen: (p) => <svg width={p.size||24} height={p.size||24} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round" className={p.className}><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l5 5"/><path d="M9.5 14.5L16 8"/></svg>,
            ArrowRight: (p) => <svg width={p.size||24} height={p.size||24} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round" className={p.className}><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>,
            RotateCcw: (p) => <svg width={p.size||24} height={p.size||24} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round" className={p.className}><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>,
            Check: (p) => <svg width={p.size||24} height={p.size||24} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="3" strokeLinecap="round" strokeLinejoin="round" className={p.className}><polyline points="20 6 9 17 4 12"/></svg>,
            X: (p) => <svg width={p.size||24} height={p.size||24} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="3" strokeLinecap="round" strokeLinejoin="round" className={p.className}><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        };

        const vocabList = [
            { word: "warn", type: "vt.", ipa: "/wɔːrn/", syllables: ["warn"], stress: 0, meaning: "警告；提醒", family: "warning (n.) 警告", matchPairs: [["issue a warning", "發佈警告"], ["warn of danger", "警告危險"]], fillBlank: { s: "Bill's parents ___ him not to go mountain climbing because a strong typhoon was coming.", a: "warned", t: "比爾的父母警告他不要去登山。" } },
            { word: "announcement", type: "n.", ipa: "/əˈnaʊns.mənt/", syllables: ["an", "nounce", "ment"], stress: 1, meaning: "公告；通知", family: "announce (v.) 宣布", matchPairs: [["make an announcement", "發表公告"], ["official announcement", "官方通知"]], fillBlank: { s: "Our English teacher made an ___ that there would be a test on Thursday.", a: "announcement", t: "老師宣佈週四將有一場考試。" } },
            { word: "research", type: "n.", ipa: "/ˈriː.sɜːrtʃ/", syllables: ["re", "search"], stress: 0, meaning: "研究", family: "researcher (n.) 研究人員", matchPairs: [["conduct research", "進行研究"], ["scientific research", "科學研究"]], fillBlank: { s: "Dr. Smith is doing some ___ into how dolphins communicate with each other.", a: "research", t: "史密斯博士正在研究海豚通訊。" } },
            { word: "flavor", type: "n.", ipa: "/ˈfleɪ.vər/", syllables: ["fla", "vor"], stress: 0, meaning: "味道；風味", family: "flavoring (n.) 調味", matchPairs: [["add flavor to", "增加風味"], ["artificial flavor", "人工調味"]], fillBlank: { s: "The tea that is grown in this mountain village has a gentle ___ of flowers.", a: "flavor", t: "這個山村種植的茶帶有淡淡花香。" } },
            { word: "pressure", type: "n.", ipa: "/ˈpreʃ.ər/", syllables: ["pres", "sure"], stress: 0, meaning: "壓力", family: "-", matchPairs: [["under great pressure", "壓力很大"], ["high blood pressure", "高血壓"]], fillBlank: { s: "The nurses are under great ___ to work long hours during the pandemic.", a: "pressure", t: "護理師們面臨超時工作的巨大壓力。" } },
            { word: "normally", type: "adv.", ipa: "/ˈnɔːr.mə.li/", syllables: ["nor", "mal", "ly"], stress: 0, meaning: "通常", family: "normal (adj.) 正常的", matchPairs: [["normally happen", "通常發生"], ["normal condition", "正常情況"]], fillBlank: { s: "Uncle Frank ___ reads the newspaper over breakfast, but today he watched TV.", a: "normally", t: "法蘭克叔叔通常邊吃早餐邊看報紙。" } },
            { word: "distinguish", type: "v.", ipa: "/dɪˈstɪŋ.ɡwɪʃ/", syllables: ["dis", "tin", "guish"], stress: 1, meaning: "分辨；區別", family: "-", matchPairs: [["distinguish between", "辨別差異"], ["distinguish A from B", "區別 A 與 B"]], fillBlank: { s: "Nancy and her twin sister look so similar that even their parents can't ___ between them.", a: "distinguish", t: "南西與她的雙胞胎姊妹長得太像了。" } },
            { word: "accurately", type: "adv.", ipa: "/ˈæk.jə.rət.li/", syllables: ["ac", "cu", "rate", "ly"], stress: 0, meaning: "精確地", family: "accurate (adj.) 精確的", matchPairs: [["predict accurately", "準確預測"], ["calculate accurately", "精確計算"]], fillBlank: { s: "So far scientists have not found a way to predict earthquakes ___.", a: "accurately", t: "到目前為止，科學家尚未能準確預測地震。" } },
            { word: "function", type: "v.", ipa: "/ˈfʌŋk.ʃən/", syllables: ["func", "tion"], stress: 0, meaning: "運作；功能", family: "functional (adj.) 實用的", matchPairs: [["perform a function", "發揮功能"], ["function as a bed", "充當床鋪"]], fillBlank: { s: "Malcolm's favorite couch also ___ as a bed when one of his friends stays over.", a: "functions", t: "這幅沙發在朋友留宿時也可以充當床鋪。" } },
            { word: "blame", type: "vt.", ipa: "/bleɪm/", syllables: ["blame"], stress: 0, meaning: "歸咎；責怪", family: "-", matchPairs: [["blame someone for", "因某事責怪某人"], ["be to blame", "該受責備"]], fillBlank: { s: "The police ___ the drunken driver for the terrible car accident.", a: "blamed", t: "警方將這場意外歸咎於該名酒駕司機。" } },
            { word: "affect", type: "vt.", ipa: "/əˈfekt/", syllables: ["af", "fect"], stress: 1, meaning: "影響", family: "effect (n.) 影響", matchPairs: [["seriously affect", "嚴重影響"], ["affect the outcome", "影響結果"]], fillBlank: { s: "Global warming has greatly ___ the lives of many wild animals.", a: "affected", t: "全球暖化已極大地影響了野生動物的生活。" } },
            { word: "passenger", type: "n.", ipa: "/ˈpæs.ən.dʒər/", syllables: ["pas", "sen", "ger"], stress: 0, meaning: "乘客", family: "-", matchPairs: [["bus passenger", "公車乘客"], ["passenger seat", "乘客座位"]], fillBlank: { s: "___ on the plane were glad to hear that the weather was fine.", a: "Passengers", t: "飛機上的乘客很高興聽到天氣良好。" } },
            { word: "distract", type: "vt.", ipa: "/dɪˈstrækt/", syllables: ["dis", "tract"], stress: 1, meaning: "使分心", family: "distraction (n.) 分心物", matchPairs: [["distract from", "使...分心"], ["easily distracted", "容易分心"]], fillBlank: { s: "The loud music from next door kept ___ Ken from his reading.", a: "distracting", t: "隔壁傳來的音樂聲一直讓肯分心。" } },
            { word: "indicate", type: "vt.", ipa: "/ˈɪn.dɪ.keɪt/", syllables: ["in", "di", "cate"], stress: 0, meaning: "指出；顯示", family: "indication (n.) 跡象", matchPairs: [["clearly indicate", "清楚指出"], ["indicate a change", "顯示改變"]], fillBlank: { s: "Recent research clearly ___ that only 3% of the children get enough exercise.", a: "indicates", t: "最近的研究指出，只有 3% 孩童運動足夠。" } },
            { word: "solution", type: "n.", ipa: "/səˈluː.ʃən/", syllables: ["so", "lu", "tion"], stress: 1, meaning: "解決方法", family: "solve (v.) 解決", matchPairs: [["find a solution", "尋找對策"], ["solution to the problem", "問題解法"]], fillBlank: { s: "The government is trying to think of a ___ to the problem of air pollution.", a: "solution", t: "政府正試圖想出解決空氣污染的方法。" } }
        ];

        const MiniMatch = ({ pairs, onWordSpeak }) => {
            const [selected, setSelected] = useState(null);
            const [completed, setCompleted] = useState([]);
            const items = useMemo(() => {
                const flat = [];
                pairs.forEach((p, idx) => {
                    flat.push({ id: `en-${idx}`, text: p[0], pair: idx, side: 'en' });
                    flat.push({ id: `zh-${idx}`, text: p[1], pair: idx, side: 'zh' });
                });
                return flat.sort(() => Math.random() - 0.5);
            }, [pairs]);

            const handleClick = (item) => {
                if (completed.includes(item.pair)) return;
                if (!selected) setSelected(item);
                else if (selected.id !== item.id && selected.side !== item.side && selected.pair === item.pair) {
                    setCompleted([...completed, item.pair]);
                    setSelected(null);
                    onWordSpeak(pairs[item.pair][0]);
                } else setSelected(item);
            };

            return (
                <div className="bg-[#FFF0F5] border-2 border-[#F9A8D4] rounded-xl p-2 animate-pop">
                    <div className="flex items-center gap-1.5 mb-1">
                        <span className="text-pink-500 text-sm">✨</span>
                        <span className="font-black text-[9px] uppercase tracking-widest text-pink-400 italic">Mini Match</span>
                    </div>
                    <div className="grid grid-cols-2 gap-1.5">
                        {items.map(it => (
                            <button key={it.id} onClick={() => handleClick(it)}
                                className={`match-item ${selected?.id === it.id ? 'selected' : ''} ${completed.includes(it.pair) ? 'correct' : ''}`}>
                                {it.text}
                            </button>
                        ))}
                    </div>
                </div>
            );
        };

        const App = () => {
            const [view, setView] = useState('login'); 
            const [user, setUser] = useState({ name: '', class: '', no: '', xp: 0 });
            const [currentWordIdx, setCurrentWordIdx] = useState(0);
            const [quizMode, setQuizMode] = useState(null); 
            const [shuffledQuiz, setShuffledQuiz] = useState([]);
            const [quizIndex, setQuizIndex] = useState(0);
            const [userInput, setUserInput] = useState('');
            const [showFeedback, setShowFeedback] = useState(false);
            const [isCorrect, setIsCorrect] = useState(null);
            const [score, setScore] = useState(0);
            const [isRecording, setIsRecording] = useState(false);
            const [recognitionText, setRecognitionText] = useState('');
            const [submitting, setSubmitting] = useState(false);

            const speak = (text) => {
                const u = new SpeechSynthesisUtterance(text);
                u.lang = 'en-US'; u.rate = 0.85;
                window.speechSynthesis.speak(u);
            };

            const startQuiz = (mode) => {
                const q = [...vocabList].sort(() => Math.random() - 0.5).slice(0, 15);
                setShuffledQuiz(q);
                setQuizMode(mode);
                setQuizIndex(0);
                setScore(0);
                setUserInput('');
                setShowFeedback(false);
                setRecognitionText('');
                setView('quiz');
            };

            const checkResult = (resultIsCorrect = null) => {
                const cur = shuffledQuiz[quizIndex];
                let ok = resultIsCorrect;
                
                if (ok === null) {
                    if(quizMode === 'spell') ok = userInput.trim().toLowerCase() === cur.word.toLowerCase();
                    if(quizMode === 'fill') ok = userInput.trim().toLowerCase() === cur.fillBlank.a.toLowerCase();
                }

                setIsCorrect(ok);
                setShowFeedback(true);
                
                if (ok || quizMode !== 'speak') {
                    if(ok) setScore(s => s + 1);
                    setTimeout(() => {
                        handleNext();
                    }, 1500);
                }
            };

            const handleNext = () => {
                if(quizIndex < shuffledQuiz.length - 1) {
                    setQuizIndex(i => i + 1);
                    setUserInput('');
                    setRecognitionText('');
                    setShowFeedback(false);
                    setIsCorrect(null);
                } else {
                    handleSubmitScore();
                }
            };

            const handleTryAgain = () => {
                setShowFeedback(false);
                setIsCorrect(null);
                setRecognitionText('');
            };

            const handleSubmitScore = async () => {
                setView('result');
                const finalPerc = Math.round((score / 15) * 100);
                if (GOOGLE_SCRIPT_URL) {
                    setSubmitting(true);
                    try {
                        await fetch(GOOGLE_SCRIPT_URL, {
                            method: 'POST',
                            mode: 'no-cors',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ name: user.name, class: user.class, no: user.no, score: finalPerc })
                        });
                    } catch (e) {}
                    setSubmitting(false);
                }
            };

            const handleStartRecording = () => {
                const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
                if (!SpeechRecognition) {
                    alert("瀏覽器不支援語音辨識。請使用 Chrome。");
                    return;
                }
                const recognition = new SpeechRecognition();
                recognition.lang = 'en-US';
                recognition.onstart = () => { setIsRecording(true); setRecognitionText(''); };
                recognition.onresult = (e) => {
                    const speech = e.results[0][0].transcript.toLowerCase().replace(/[.,!?;:]/g, "").trim();
                    const target = shuffledQuiz[quizIndex].word.toLowerCase();
                    setRecognitionText(speech);
                    const ok = (speech.includes(target) || target.includes(speech));
                    checkResult(ok);
                };
                recognition.onerror = () => setIsRecording(false);
                recognition.onend = () => setIsRecording(false);
                recognition.start();
            };

            if (view === 'login') {
                return (
                    <div className="flex-1 flex items-center justify-center p-6">
                        <div className="brutal-card-heavy w-full p-8 rounded-[32px] text-center">
                            <div className="w-16 h-16 bg-[#FDE047] rounded-full border-4 border-black flex items-center justify-center mx-auto mb-6 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]"><Icons.Zap size={32} /></div>
                            <h1 className="text-3xl font-black italic tracking-tighter mb-1"><span className="text-[#5D5FEF]">VOCAB</span><span className="text-[#D946EF]">POP</span></h1>
                            <p className="text-slate-400 font-bold text-xs mb-8 tracking-[0.2em] uppercase">Student Login</p>
                            <form className="space-y-4 text-left" onSubmit={e => { e.preventDefault(); if(user.name&&user.class&&user.no) setView('learn'); }}>
                                <div className="flex gap-3 w-full">
                                    <div className="flex-1 min-w-0">
                                        <label className="block font-black mb-1 text-[10px] uppercase text-slate-500">Class *</label>
                                        <input className="brutal-input" placeholder="104" value={user.class} onChange={e => setUser({...user, class: e.target.value})} required />
                                    </div>
                                    <div className="flex-1 min-w-0">
                                        <label className="block font-black mb-1 text-[10px] uppercase text-slate-500">No. *</label>
                                        <input className="brutal-input" placeholder="15" value={user.no} onChange={e => setUser({...user, no: e.target.value})} required />
                                    </div>
                                </div>
                                <div><label className="block font-black mb-1 text-[10px] uppercase text-slate-500">Name *</label><input className="brutal-input" placeholder="姓名" value={user.name} onChange={e => setUser({...user, name: e.target.value})} required /></div>
                                <button type="submit" className="w-full py-4 bg-[#5D5FEF] text-white rounded-xl font-black text-lg brutal-btn flex items-center justify-center gap-3 mt-4 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">START JOURNEY <Icons.ArrowRight size={20} /></button>
                            </form>
                        </div>
                    </div>
                );
            }

            const NavHeader = () => (
                <div className="w-full px-4 pt-3 pb-1 sticky top-0 z-50">
                    <div className="brutal-card bg-white rounded-2xl p-2.5 flex justify-between items-center shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
                        <div className="flex items-center gap-2">
                            <Icons.Zap size={18} className="text-yellow-400 fill-current" />
                            <div className="flex flex-col"><span className="font-black text-xs italic leading-none"><span className="text-[#5D5FEF]">VOCAB</span> <span className="text-[#D946EF]">POP</span></span><span className="text-[7px] text-slate-400 font-bold uppercase mt-1 leading-none">{user.class}班 {user.no}號 {user.name}</span></div>
                        </div>
                        <div className="bg-black text-white rounded-full px-3 py-1 flex items-center gap-2 text-[8px] font-black"><span className="text-yellow-400">★ LV.1</span><span className="text-slate-500">|</span><span>{user.xp} XP</span></div>
                    </div>
                    <div className="flex gap-2 mt-2 px-1">
                        <button onClick={() => setView('learn')} className={`flex-1 py-2 brutal-btn rounded-xl font-black text-[10px] flex items-center justify-center gap-1.5 transition-all ${view === 'learn' ? 'bg-[#A5F3FC] translate-y-0.5 shadow-none' : 'bg-white'}`}><Icons.Book size={12} /> LEARN</button>
                        <button onClick={() => setView('coach')} className={`flex-1 py-2 brutal-btn rounded-xl font-black text-[10px] flex items-center justify-center gap-1.5 transition-all ${view === 'coach' ? 'bg-[#F9A8D4] translate-y-0.5 shadow-none' : 'bg-white'}`}><Icons.Coach size={12} /> COACH</button>
                    </div>
                </div>
            );

            if (view === 'learn') {
                const w = vocabList[currentWordIdx];
                return (
                    <div className="flex-1 flex flex-col pb-4">
                        <NavHeader />
                        <div className="px-4 mt-1 animate-pop">
                            <div className="brutal-card-heavy rounded-[32px] overflow-hidden">
                                <div className="bg-[#5D5FEF] p-4 text-center pattern-dots relative">
                                    <div className="absolute top-2 left-2 bg-black text-white text-[8px] font-black px-2 py-0.5 rounded-md">{w.type}</div>
                                    <div className="bg-black/20 text-white text-[9px] font-bold px-3 py-0.5 rounded-full inline-block mb-1">{w.ipa}</div>
                                    <h2 className="text-3xl font-black text-white mb-2 tracking-tight">{w.word}</h2>
                                    <div className="flex justify-center gap-1.5 mb-4">{w.syllables.map((s, i) => <div key={i} className={`syllable-bubble ${i === w.stress ? 'bg-[#FDE047]' : 'bg-white/30 text-white border-white/40'}`}>{s}</div>)}</div>
                                    <button onClick={() => speak(w.word)} className="w-10 h-10 bg-white rounded-full flex items-center justify-center mx-auto brutal-btn shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]"><Icons.Volume2 size={20} /></button>
                                </div>
                                <div className="p-3.5 space-y-3">
                                    <div className="space-y-1">
                                        <h3 className="font-black text-[10px] flex items-center gap-1 uppercase tracking-widest text-slate-800"><div className="w-1.5 h-1.5 bg-yellow-400 border border-black rounded-full"></div> Meaning</h3>
                                        <p className="text-slate-600 font-bold text-xs leading-snug border-l-3 border-slate-100 pl-2">{w.meaning}</p>
                                    </div>
                                    <div className="bg-emerald-50/50 p-2 rounded-lg border-2 border-emerald-100"><p className="text-[10px] font-bold text-slate-700 italic leading-snug">"{w.fillBlank.s.replace('___', w.word)}"</p></div>
                                    <MiniMatch key={w.word} pairs={w.matchPairs} onWordSpeak={speak} />
                                    <div className="flex justify-between items-center pt-1">
                                        <button disabled={currentWordIdx === 0} onClick={() => setCurrentWordIdx(i => i-1)} className="px-3 py-2 brutal-btn bg-slate-100 rounded-xl font-black text-[10px]">PREV</button>
                                        <button onClick={() => setCurrentWordIdx(i => (i+1)%vocabList.length)} className="px-6 py-2 brutal-btn bg-[#FDE047] rounded-xl font-black text-[10px]">NEXT</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                );
            }

            if (view === 'coach') {
                return (
                    <div className="flex-1 flex flex-col overflow-hidden">
                        <NavHeader />
                        <div className="px-4 mt-2 mb-4 space-y-2 flex-1 flex flex-col justify-between animate-pop">
                            {[
                                { m: 'speak', t: 'PRO SPEAK', d: '發音挑戰 (隨機 15 題)', c: '#86EFAC', i: <Icons.Mic size={24}/> },
                                { m: 'spell', t: 'SPELL IT', d: '聽寫挑戰 (15 題)', c: '#93C5FD', i: <Icons.Keyboard size={24}/> },
                                { m: 'fill', t: 'FILL IN', d: '例句克漏字 (15 題)', c: '#FDBA74', i: <Icons.Pen size={24}/> }
                            ].map((b, i) => (
                                <button key={i} onClick={() => startQuiz(b.m)} className="flex-1 brutal-card-heavy p-3 flex items-center gap-3 rounded-2xl min-h-[85px]" style={{backgroundColor: b.c}}>
                                    <div className="bg-white p-2 rounded-xl border-2 border-black shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">{b.i}</div>
                                    <div className="text-left leading-tight"><div className="font-black text-base mb-0.5">{b.t}</div><div className="text-[8px] font-bold opacity-60 uppercase">{b.d}</div></div>
                                    <Icons.ArrowRight size={18} className="ml-auto opacity-30" />
                                </button>
                            ))}
                        </div>
                    </div>
                );
            }

            if (view === 'quiz') {
                const cur = shuffledQuiz[quizIndex];
                return (
                    <div className="flex-1 flex flex-col p-4 animate-pop overflow-hidden">
                        <div className="flex justify-between items-center mb-2.5">
                            <button onClick={() => setView('coach')} className="px-2.5 py-1 brutal-btn bg-white rounded-lg flex items-center gap-1 text-[9px] font-black shadow-[2px_2px_0px_0px_#000]"><Icons.RotateCcw size={10}/> EXIT</button>
                            <div className="font-black text-[9px] bg-black text-white px-2.5 py-1 rounded-full">{quizIndex + 1} / {shuffledQuiz.length}</div>
                        </div>
                        <div className="brutal-card-heavy rounded-[24px] p-4 flex-1 flex flex-col justify-center items-center relative min-h-[250px] mb-4">
                            {quizMode === 'spell' && <div className="w-full text-center"><button onClick={() => speak(cur.word)} className="w-14 h-14 bg-[#A5F3FC] rounded-full brutal-btn flex items-center justify-center mb-4 mx-auto"><Icons.Volume2 size={28}/></button><p className="text-slate-800 font-bold text-xs leading-relaxed mb-6">"{cur.meaning}"</p><input autoFocus className="underline-input" placeholder="Type here..." value={userInput} onChange={e => setUserInput(e.target.value)} onKeyPress={e => e.key === 'Enter' && userInput && checkResult()}/></div>}
                            {quizMode === 'fill' && <div className="text-left w-full"><p className="text-base font-black leading-relaxed mb-4">{cur.fillBlank.s.split('___')[0]}<span className="text-[#5D5FEF] border-b-2 border-black px-1">{userInput || '____'}</span>{cur.fillBlank.s.split('___')[1]}</p><p className="text-[9px] text-slate-400 mb-6 italic border-l-3 pl-2 leading-tight">{cur.fillBlank.t}</p><input autoFocus className="underline-input" placeholder="Fill in..." value={userInput} onChange={e => setUserInput(e.target.value)} onKeyPress={e => e.key === 'Enter' && userInput && checkResult()}/></div>}
                            {quizMode === 'speak' && <div className="w-full text-center"><h2 className="text-4xl font-black mb-1 tracking-tighter text-slate-900">{cur.word}</h2><div className="bg-black/5 px-3 py-0.5 rounded-lg text-slate-400 text-[8px] font-black mb-6 italic">{cur.ipa}</div><div className="flex gap-1.5 justify-center mb-6">{cur.syllables.map((s, i) => <div key={i} className={`syllable-bubble ${i === cur.stress ? 'bg-[#FDE047]' : 'bg-white'}`}>{s}</div>)}</div>{recognitionText && <p className="text-blue-500 font-black text-[10px] animate-bounce">👂 Hearing: "{recognitionText}"</p>}</div>}
                            {showFeedback && <div className={`absolute -bottom-3 left-1/2 -translate-x-1/2 p-3 rounded-lg border-2 border-black font-black w-[80%] text-center text-xs shadow-[3px_3px_0px_0px_#000] ${isCorrect ? 'bg-[#86EFAC]' : 'bg-[#FCA5A5]'}`}>{isCorrect ? '✨ CORRECT!' : (quizMode === 'speak' ? '❌ TRY AGAIN?' : `❌ ANS: ${quizMode === 'spell' ? cur.word : cur.fillBlank.a}`)}</div>}
                        </div>
                        {quizMode === 'speak' && (
                            <div className="flex flex-col items-center pb-4">
                                {!showFeedback || isCorrect ? (
                                    <>
                                        <button onClick={handleStartRecording} className={`w-16 h-16 rounded-full brutal-btn flex items-center justify-center mb-3 transition-all ${isRecording ? 'mic-recording bg-red-500' : 'bg-[#FDE047]'}`}><Icons.Mic size={32} className={isRecording ? 'text-white' : ''} /></button>
                                        <div className="bg-white border-2 border-black px-4 py-1.5 rounded-full font-black text-[9px] uppercase tracking-widest shadow-[2px_2px_0px_0px_#000]">{isRecording ? 'Listening...' : 'Tap to Record'}</div>
                                    </>
                                ) : (
                                    <div className="flex gap-3 w-full px-2 animate-pop">
                                        <button onClick={handleTryAgain} className="flex-1 py-3 bg-[#FDE047] rounded-xl brutal-btn font-black text-xs flex items-center justify-center gap-1.5"><Icons.RotateCcw size={14}/> TRY AGAIN</button>
                                        <button onClick={handleNext} className="flex-1 py-3 bg-white rounded-xl brutal-btn font-black text-xs flex items-center justify-center gap-1.5 text-slate-500">SKIP <Icons.ArrowRight size={14}/></button>
                                    </div>
                                )}
                            </div>
                        )}
                        {!showFeedback && quizMode !== 'speak' && (
                            <button onClick={() => checkResult()} disabled={!userInput} className="w-full py-3 bg-black text-white rounded-xl font-black text-base brutal-btn shadow-[4px_4px_0px_0px_#000] mb-4">CHECK ANSWER</button>
                        )}
                    </div>
                );
            }

            if (view === 'result') {
                return (
                    <div className="flex-1 flex items-center justify-center p-8 text-center animate-pop">
                        <div className="brutal-card-heavy w-full p-8 rounded-[40px] bg-white">
                            <div className="w-16 h-16 bg-[#FDE047] rounded-2xl border-4 border-black flex items-center justify-center mx-auto mb-4 rotate-6 shadow-[4px_4px_0px_0px_#000]"><Icons.Zap size={32} /></div>
                            <h2 className="text-xl font-black mb-1 italic uppercase">Challenge Done!</h2>
                            <p className="text-slate-400 font-bold text-[9px] mb-6 uppercase tracking-widest">{user.name}'s SCORE</p>
                            <div className="text-8xl font-black text-[#5D5FEF] mb-10 tracking-tighter">{Math.round((score/15)*100)}<span className="text-lg text-slate-300 ml-1">pts</span></div>
                            <button onClick={() => setView('coach')} className="w-full py-3.5 bg-black text-white rounded-xl font-black text-base brutal-btn shadow-[4px_4px_0px_0px_#000]">BACK TO COACH</button>
                        </div>
                    </div>
                );
            }
            return null;
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
